{
  "title": "ModelOps — Credit Card Default",
  "uid": "modelops-credit",
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/min)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [{
        "expr": "rate(modelops_predictions_total[1m]) * 60",
        "legendFormat": "class {{prediction}}"
      }]
    },
    {
      "id": 2,
      "title": "Prediction Latency p50/p95/p99",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {"expr": "histogram_quantile(0.50, rate(modelops_prediction_latency_seconds_bucket[5m]))", "legendFormat": "p50"},
        {"expr": "histogram_quantile(0.95, rate(modelops_prediction_latency_seconds_bucket[5m]))", "legendFormat": "p95"},
        {"expr": "histogram_quantile(0.99, rate(modelops_prediction_latency_seconds_bucket[5m]))", "legendFormat": "p99"}
      ]
    },
    {
      "id": 3,
      "title": "Prediction Class Distribution",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [{
        "expr": "rate(modelops_predictions_total{prediction='1'}[5m]) / rate(modelops_predictions_total[5m])",
        "legendFormat": "% default predicted"
      }]
    },
    {
      "id": 4,
      "title": "Probability Distribution (Drift Indicator)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [{
        "expr": "histogram_quantile(0.50, rate(modelops_prediction_probability_bucket[5m]))",
        "legendFormat": "median probability"
      }]
    },
    {
      "id": 5,
      "title": "Current Model Version",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 16},
      "targets": [{"expr": "modelops_model_version", "legendFormat": "version"}]
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
